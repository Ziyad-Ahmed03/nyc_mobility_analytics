# ============================================================
# NYC Mobility Analytics — Environment Configuration
# ============================================================
# Copy this file to .env and adjust values as needed:
#   cp config/config.env .env

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nyc_mobility
POSTGRES_USER=nyc_user
POSTGRES_PASSWORD=nyc_pass_2025

# Airflow internal DB
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_DB_NAME=airflow

# ── Airflow ────────────────────────────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@nyc-mobility.io
FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLt0jKKjY=
SECRET_KEY=nyc_mobility_secret_2025

# ── Paths ──────────────────────────────────────────────────
NYC_DATA_DIR=/opt/airflow/data
SPARK_DRIVER_MEMORY=4g
SPARK_EXECUTOR_MEMORY=4g

# ── Dashboard ──────────────────────────────────────────────
STREAMLIT_PORT=8501
DASHBOARD_TITLE=NYC Mobility Analytics
